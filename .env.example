# ============================================================
#  Highlight Extractor — Environment Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ---------------------------------------------------------------------------
# API Authentication
# ---------------------------------------------------------------------------
# Used to authenticate requests to the FastAPI backend.
# Generate a strong random string (e.g. `openssl rand -hex 32`)
APP_API_KEY=your_secure_api_key_here

# ---------------------------------------------------------------------------
# AI Organization (Optional)
# ---------------------------------------------------------------------------
# Required for the "✨ Summarize with AI" feature.
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model for AI clustering.
# ⚠️  Flash-Lite IDs change frequently — verify the current string at:
#     https://ai.google.dev/gemini-api/docs/models
#     Current GA as of 2026-07: gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite

# API server settings
API_HOST=127.0.0.1
API_PORT=8000

# Environment (development | production)
ENV=development
